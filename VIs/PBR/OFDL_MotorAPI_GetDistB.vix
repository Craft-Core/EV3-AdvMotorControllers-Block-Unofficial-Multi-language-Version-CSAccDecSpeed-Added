                </ConfigurableMethodCall>
                <!-- DistMM = delta * diam * 3.14159 / 360 -->
                <ConfigurableMethodCall Id="nMath2" Bounds="1060 163 225 91" Target="X3Placeholder_2A058539\-ED76\-4476\-93FE\-CCE8AA559C5A_MathEquation\.vix">
                    <ConfigurableMethodTerminal ConfiguredValue="1">

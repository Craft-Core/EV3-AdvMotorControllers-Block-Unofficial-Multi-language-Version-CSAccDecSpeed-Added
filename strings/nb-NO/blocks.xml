        <PolyGroup Name="OFDL PD ColorSpeed Controller" DisplayName="Color Sensor Speed Controller" DisplayNamePrefix="OFDL PD ColorSpeed Controller">
            <Parameter Name="P1" DisplayName="Color Sensor Input 1">
                <Description><![CDATA[<p>Color Sensor Input 1</p>]]></Description>
            </Parameter>
            <Parameter Name="P2" DisplayName="Color Sensor Input 2">
                <Description><![CDATA[<p>Color Sensor Input 2</p>]]></Description>
            </Parameter>
            <Parameter Name="BaseSpeed" DisplayName="Base Speed">
                <Description><![CDATA[<p>Base speed</p>]]></Description>
            </Parameter>
            <Parameter Name="MinSpeed" DisplayName="Minimum Speed">
                <Description><![CDATA[<p>Minimum speed</p>]]></Description>
            </Parameter>
            <Parameter Name="MaxError" DisplayName="Maximum Error">
                <Description><![CDATA[<p>Maximum error</p>]]></Description>
            </Parameter>
            <Parameter Name="SmoothEnable" DisplayName="Smooth Enable">
                <Description><![CDATA[<p>Enable smooth speed transition (0=Off, 1=On)</p>]]></Description>
            </Parameter>
            <Parameter Name="SmoothLevel" DisplayName="Smooth Level">
                <Description><![CDATA[<p>Smoothness level (1=instant, 100=very gradual)</p>]]></Description>
            </Parameter>
            <Parameter Name="SpeedOut" DisplayName="Speed Output">
                <Description><![CDATA[<p>Speed output</p>]]></Description>
            </Parameter>
            <Parameter Name="CS1Out" DisplayName="Color Sensor 1 Output">
                <Description><![CDATA[<p>Color sensor output</p>]]></Description>
            </Parameter>
            <Parameter Name="CS2Out" DisplayName="Color Sensor 2 Output">
                <Description><![CDATA[<p>Color sensor output</p>]]></Description>
            </Parameter>
            <Description><![CDATA[<p>Calculates motor speed based on the difference between two color sensor values for PD line following.</p>]]></Description>
            <Block Mode="CS_Linear" DisplayName="CS Linear Speed">
                <Description><![CDATA[<p>Linearly reduces speed proportional to the color sensor error. Recommended for most line-following tasks.</p>]]></Description>
            </Block>
            <Block Mode="CS_Quadratic" DisplayName="CS Quadratic Speed">
                <Description><![CDATA[<p>Reduces speed with the square of the error. Stays fast near the line and drops quickly when off-track.</p>]]></Description>
            </Block>
            <Block Mode="CS_Sqrt" DisplayName="CS Sqrt Speed">
                <Description><![CDATA[<p>Reduces speed with the square root of the error. Drops quickly for small errors, gentler for large ones.</p>]]></Description>
            </Block>
            <Block Mode="CS_Step" DisplayName="CS Step Speed">
                <Description><![CDATA[<p>Uses three discrete speed levels based on error thresholds. Easy to tune manually.</p>]]></Description>
            </Block>
                        <Block Mode="CS_Cubic" DisplayName="CS Cubic Speed ★★★★★ Best for competition">
                <Description><![CDATA[<p>Reduces speed with the cube of the error. Stays at maximum speed near the line and drops steeply when off-track. Recommended most for competition fastest-lap scenarios.</p>]]></Description>
            </Block>
            <Block Mode="CS_Smooth" DisplayName="CS Smooth Speed ★★★★ Stable recommended">
                <Description><![CDATA[<p>Uses smoothstep curve (3t-2t3) for speed reduction. No abrupt speed changes - accelerates and decelerates smoothly. Best for stable line following.</p>]]></Description>
            </Block>
            <Block Mode="Configuration" DisplayName="Configuration">
                <Description><![CDATA[<p>Sets BaseSpeed, MinSpeed, and MaxError configuration values for the Color Sensor Speed Controller.</p>]]></Description>
            </Block>
        </PolyGroup>
